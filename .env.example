# Copy this to .env and fill in real values.

# Slack incoming webhook URL
SLACK_WEBHOOK_URL="" # leave empty ot skip slack notifications

# Your domain (cloud) or localhost (local)
DOMAIN=localhost

# Port the daemon dashboard is served on
DAEMON_PORT=8080

# Paths inside the containers — defaults are correct, change only if you know why
LOG_PATH=/var/log/nginx/hng-access.log
AUDIT_LOG_PATH=/var/log/ddos-daemon/audit.log

# Let's Encrypt email (cloud only)
LETSENCRYPT_EMAIL=email@email.com

# Memory cap for Nextcloud PHP workers
NEXTCLOUD_MEMORY_LIMIT=768M
